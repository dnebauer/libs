# fn_tag dnIniSettingAllowSpacesInNames note The default value for this setting is true, that is, enabled
# fn_tag dnIniSettingAllowSpacesInNames param value purpose setting value
# fn_tag dnIniSettingAllowSpacesInNames param value required no
# fn_tag dnIniSettingAllowSpacesInNames param value multipart no
# fn_tag dnIniSettingAllowSpacesInNames param value type string
# fn_tag dnIniSettingAllowSpacesInNames param value value 'true'
# fn_tag dnIniSettingAllowSpacesInNames param value value 'false'
# fn_tag dnIniSettingAllowSpacesInNames param value note the values for this parameter are text strings, not the shell built-in commands
dnIniSettingAllowSpacesInNames() {
  __dnIniSetting 'allow_spaces_in_names' "$@"
  return $?
}

# Function: dnIniSettingDebug    {{{1
# Getter/setter for the 'debug' library setting
#   params: value - setting value [string, optional, allowed='true'|'false', no default]
#   prints: nil
#   return: setter=nil, getter=boolean setting value
#   note:   call with no parameter as getter, call with 1 parameter as setter
#   note:   the default value for this setting is false, that is, disabled
# fn_tag dnIniSettingDebug purpose Getter/setter for the 'debug' setting
# fn_tag dnIniSettingDebug prints NIL
# fn_tag dnIniSettingDebug returns Getter: boolean setting value, Setter: NIL
# fn_tag dnIniSettingDebug note Call with no parameter as getter, call with 1 parameter as setter
# fn_tag dnIniSettingDebug note The default value for this setting is false, that is, disabled
# fn_tag dnIniSettingDebug param value purpose setting value
# fn_tag dnIniSettingDebug param value required no
# fn_tag dnIniSettingDebug param value multipart no
# fn_tag dnIniSettingDebug param value type string
# fn_tag dnIniSettingDebug param value value 'true'
# fn_tag dnIniSettingDebug param value value 'false'
# fn_tag dnIniSettingDebug param value note the values for this parameter are text strings, not the shell built-in commands
dnIniSettingDebug() {
  __dnIniSetting 'debug' "$@"
  return $?
}

# Function: dnIniSettingStrict    {{{1
# Getter/setter for the 'strict' library setting
#   params: value - setting value [string, optional, allowed='true'|'false', no default]
#   prints: nil
#   return: setter=nil, getter=boolean setting value
#   note:   call with no parameter as getter, call with 1 parameter as setter
#   note:   the default value for this setting is false, that is, disabled
# fn_tag dnIniSettingStrict purpose Getter/setter for the 'strict' setting
# fn_tag dnIniSettingStrict prints NIL
# fn_tag dnIniSettingStrict returns Getter: boolean setting value, Setter: NIL
# fn_tag dnIniSettingStrict note Call with no parameter as getter, call with 1 parameter as setter
# fn_tag dnIniSettingStrict note The default value for this setting is false, that is, disabled
# fn_tag dnIniSettingStrict param value purpose setting value
# fn_tag dnIniSettingStrict param value required no
# fn_tag dnIniSettingStrict param value multipart no
# fn_tag dnIniSettingStrict param value type string
# fn_tag dnIniSettingStrict param value value 'true'
# fn_tag dnIniSettingStrict param value value 'false'
# fn_tag dnIniSettingStrict param value note the values for this parameter are text strings, not the shell built-in commands
dnIniSettingStrict() {
  __dnIniSetting 'strict' "$@"
  return $?
}

# Function: dnIniToEnv    {{{1
# Export key values to environmental variables
#   params: file    - ini file [path, required, must exist]
#           prefix  - variable name prefix [string, optional, default='']
#           section - section name [string, optional, default=all sections]
#   prints: error messages
#   return: boolean
#   note:   environmental variable name format depends on prefix parameter
#           empty prefix = 'section_key'
#           non-empty prefix = 'prefix_section_key'
# fn_tag dnIniToEnv purpose Export ini file key values to environmental variables
# fn_tag dnIniToEnv prints Error messages
# fn_tag dnIniToEnv returns Boolean (error status if invalid params)
# fn_tag dnIniToEnv note Environmental variable name format depends on 'prefix' param:
# fn_tag dnIniToEnv note • empty prefix = 'section_key'
# fn_tag dnIniToEnv note • non-empty prefix = 'prefix_section_key'
# fn_tag dnIniToEnv param file purpose ini file to read
# fn_tag dnIniToEnv param file required yes
# fn_tag dnIniToEnv param file multipart no
# fn_tag dnIniToEnv param file type path
# fn_tag dnIniToEnv param prefix purpose prefix added to each variable name
# fn_tag dnIniToEnv param prefix required no
# fn_tag dnIniToEnv param prefix multipart no
# fn_tag dnIniToEnv param prefix type string
# fn_tag dnIniToEnv param prefix default empty string ('')
# fn_tag dnIniToEnv param section purpose section variable to export
# fn_tag dnIniToEnv param section required no
# fn_tag dnIniToEnv param section multipart no
# fn_tag dnIniToEnv param section type string
# fn_tag dnIniToEnv param section default all sections
dnIniToEnv() {
  # validate parameters
  if [ $# -lt 1 ]; then
    __dnIniError "${FUNCNAME[0]}: Missing file parameter"
    return 1
  fi
  local file prefix section
  file="$1"
  prefix=''
  if [ $# -ge 2 ]; then
    prefix="$2"
  fi
  section=''
  if [ $# -ge 3 ]; then
    section="$3"
  fi
  if [ -z "$file" ]; then
    __dnIniError "${FUNCNAME[0]}: Missing file parameter"
    return 1
  fi

  # check if file exists
  if [ ! -f "$file" ]; then
    __dnIniError "${FUNCNAME[0]}: File not found: $file"
    return 1
  fi

  __dnIniDebug "Exporting INI values to environment variables with prefix: $prefix"

  # if section is specified, only export keys from that section
  if [ -n "$section" ]; then
    if __dnIniSetting 'strict'; then
      __dnIniValidateSectionName "$section" || return 1
    fi

    local keys
    keys=$(dnIniListKeys "$file" "$section")

    for key in $keys; do
      local value
      value=$(dnIniRead "$file" "$section" "$key")

      # export the variable with the given prefix
      if [ -n "$prefix" ]; then
        export "${prefix}_${section}_${key}=${value}"
      else
        export "${section}_${key}=${value}"
      fi
    done
  else
    # export keys from all sections
    local sections
    sections=$(dnIniListSections "$file")

    for section in $sections; do
      local keys
      keys=$(dnIniListKeys "$file" "$section")

      for key in $keys; do
        local value
        value=$(dnIniRead "$file" "$section" "$key")

        # export the variable with the given prefix
        if [ -n "$prefix" ]; then
          export "${prefix}_${section}_${key}=${value}"
        else
          export "${section}_${key}=${value}"
        fi
      done
    done
  fi

  __dnIniDebug "Environment variables set successfully"
  return 0
}

# Function: dnIniWrite    {{{1
# Write a scalar key value to an ini file
#   params: file    - ini file [path, required, must exist]
#           section - section to contain key [string, required, need not exist]
#           key     - key name [string, required, need not exist]
#           value   - key value [string, optional, default='']
#   prints: error messages
#   return: boolean
# fn_tag dnIniWrite purpose Write a scalar key value to an ini file
# fn_tag dnIniWrite prints Error messages
# fn_tag dnIniWrite returns Boolean (error status if invalid params)
# fn_tag dnIniWrite note Used for scalar values - use 'dnIniWriteArray' for array values
# fn_tag dnIniWrite param file purpose ini file to edit
# fn_tag dnIniWrite param file required yes
# fn_tag dnIniWrite param file multipart no
# fn_tag dnIniWrite param file type path
# fn_tag dnIniWrite param file note file must exist
# fn_tag dnIniWrite param section purpose section to contain key
# fn_tag dnIniWrite param section required yes
# fn_tag dnIniWrite param section multipart no
# fn_tag dnIniWrite param section type string
# fn_tag dnIniWrite param section note section need not exist
# fn_tag dnIniWrite param key purpose key name
# fn_tag dnIniWrite param key required yes
# fn_tag dnIniWrite param key multipart no
# fn_tag dnIniWrite param key type string
# fn_tag dnIniWrite param key note if key exists it is overwritten
# fn_tag dnIniWrite param value purpose key value
# fn_tag dnIniWrite param value required no
# fn_tag dnIniWrite param value multipart no
# fn_tag dnIniWrite param value type string
# fn_tag dnIniWrite param value default empty string ('')
dnIniWrite() {
  # validate parameters
  if [ $# -lt 3 ]; then
    __dnIniError "${FUNCNAME[0]}: Missing required parameters"
    return 1
  fi
  local file section key value
  file="$1"
  section="$2"
  key="$3"
  value=''
  if [ $# -ge 4 ]; then
    value="$4"
  fi
  if [ -z "$file" ] || [ -z "$section" ] || [ -z "$key" ]; then
    __dnIniError "${FUNCNAME[0]}: Missing required parameters"
    return 1
  fi

  # validate section and key names only if strict mode is enabled
  if __dnIniSetting 'strict'; then
    __dnIniValidateSectionName "$section" || return 1
    __dnIniValidateKeyName "$key" || return 1
  fi

  # check for empty value if not allowed
  if [ -z "$value" ] && ! __dnIniSetting 'allow_empty_values'; then
    __dnIniError "${FUNCNAME[0]}: Empty values are not allowed"
    return 1
  fi

  # check and create file if needed
  __dnIniCheckFile "$file" || return 1

  # create section if it doesn't exist
  dnIniAddSection "$file" "$section" || return 1

  # escape section and key for regex pattern
  local escaped_section
  escaped_section=$(__dnIniEscapeForRegex "$section")
  local escaped_key
  escaped_key=$(__dnIniEscapeForRegex "$key")

  local section_pattern key_pattern in_section found_key temp_file
  section_pattern="^\[$escaped_section\]"
  key_pattern="^[[:space:]]*${escaped_key}[[:space:]]*="
  in_section=1
  found_key=1
  temp_file=$(__dnIniCreateTempFile)

  __dnIniDebug "Writing key '$key' with value '$value' to section '$section' in file: $file"

  # special handling for values with quotes or special characters
  if __dnIniSetting 'strict' && [[ "$value" =~ [[:space:]\"\'\`\&\|\<\>\;\$] ]]; then
    value="\"${value//\"/\\\"}\""
    __dnIniDebug "Value contains special characters, quoting: $value"
  fi

  # process the file line by line
  while IFS= read -r line || [ -n "$line" ]; do
    # check for section
    if [[ "$line" =~ $section_pattern ]]; then
      in_section=0
      echo "$line" >>"$temp_file"
      continue
    fi

    # check if we've moved to a different section
    if [[ $in_section -eq 0 && "$line" =~ ^\[[^]]+\] ]]; then
      # add the key-value pair if we haven't found it yet
      if [ $found_key -eq 1 ]; then
        echo "$key=$value" >>"$temp_file"
        found_key=0
      fi
      in_section=1
    fi

    # update the key if it exists in the current section
    if [[ $in_section -eq 0 && "$line" =~ $key_pattern ]]; then
      echo "$key=$value" >>"$temp_file"
      found_key=0
      continue
    fi

    # write the line to the temp file
    echo "$line" >>"$temp_file"
  done <"$file"

  # add the key-value pair if we're still in the section and haven't found it
  if [ $in_section -eq 0 ] && [ $found_key -eq 1 ]; then
    echo "$key=$value" >>"$temp_file"
  fi

  # use atomic operation to replace the original file
  mv "$temp_file" "$file"

  __dnIniDebug "Successfully wrote key '$key' with value '$value' to section '$section'"
  return 0
}

# Function: dnIniWriteArray    {{{1
# Write a array key value to an ini file
#   params: file    - ini file [path, required, must exist]
#           section - section to contain key [string, required, need not exist]
#           key     - key name [string, required, need not exist]
#           value   - key value [string, optional, default='']
#   prints: error messages
#   return: boolean
# fn_tag dnIniWriteArray purpose Write a scalar key value to an ini file
# fn_tag dnIniWriteArray prints Error messages
# fn_tag dnIniWriteArray returns Boolean (error status if invalid params)
# fn_tag dnIniWriteArray note Used for scalar values - use 'dnIniWriteArray' for array values
# fn_tag dnIniWriteArray param file purpose ini file to edit
# fn_tag dnIniWriteArray param file required yes
# fn_tag dnIniWriteArray param file multipart no
# fn_tag dnIniWriteArray param file type path
# fn_tag dnIniWriteArray param file note file must exist
# fn_tag dnIniWriteArray param section purpose section to contain key
# fn_tag dnIniWriteArray param section required yes
# fn_tag dnIniWriteArray param section multipart no
# fn_tag dnIniWriteArray param section type string
# fn_tag dnIniWriteArray param section note section need not exist
# fn_tag dnIniWriteArray param key purpose key name
# fn_tag dnIniWriteArray param key required yes
# fn_tag dnIniWriteArray param key multipart no
# fn_tag dnIniWriteArray param key type string
# fn_tag dnIniWriteArray param key note if key exists it is overwritten
# fn_tag dnIniWriteArray param value purpose key value
# fn_tag dnIniWriteArray param value required no
# fn_tag dnIniWriteArray param value multipart no
# fn_tag dnIniWriteArray param value type string
# fn_tag dnIniWriteArray param value default empty string ('')
dnIniWriteArray() {
  local file section key
  file="$1"
  section="$2"
  key="$3"
  shift 3
  local -a array_values
  array_values=("$@")

  # validate parameters
  if [ -z "$file" ] || [ -z "$section" ] || [ -z "$key" ]; then
    __dnIniError "${FUNCNAME[0]}: Missing required parameters"
    return 1
  fi

  # process array values and handle quoting
  local array_string first
  array_string=""
  first=0

  for value in "${array_values[@]}"; do
    # add comma separator if not the first item
    if [ $first -eq 1 ]; then
      array_string="$array_string,"
    else
      first=1
    fi

    # quote values with spaces or special characters
    if [[ "$value" =~ [[:space:],\"] ]]; then
      # escape quotes
      value="${value//\"/\\\"}"
      array_string="$array_string\"$value\""
    else
      array_string="$array_string$value"
    fi
  done

  # write the array string to the ini file
  dnIniWrite "$file" "$section" "$key" "$array_string"
  return $?
}
# }}}1

# vim:foldmethod=marker:
